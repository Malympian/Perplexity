{
  "manifest_version": 3,
  "name": "Text Obfuscator",
  "version": "1.1",
  "description": "Add invisible characters and homoglyphs to text with adjustable frequency",
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Text Obfuscator",
    "default_icon": {
      "128": "icon128.png"
    }
  }
}
